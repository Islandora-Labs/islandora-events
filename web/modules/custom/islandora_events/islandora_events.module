<?php

/**
 * @file
 * Primary module hooks for Islandora Events module.
 *
 * Procedural hook entry points delegate to service classes so the module stays
 * compatible with both Drupal 10 and 11.
 */

use Drupal\taxonomy\TermInterface;
use Drupal\file\FileInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Url;
use Drupal\sm_ledger\Entity\EventRecordInterface;

/**
 * Implements hook_node_insert().
 */
function islandora_events_node_insert(EntityInterface $node): void {
  \Drupal::service('islandora_events.entity_hooks')->nodeInsert($node);
}

/**
 * Implements hook_node_update().
 */
function islandora_events_node_update(EntityInterface $node): void {
  \Drupal::service('islandora_events.entity_hooks')->nodeUpdate($node);
}

/**
 * Implements hook_node_delete().
 */
function islandora_events_node_delete(EntityInterface $node): void {
  \Drupal::service('islandora_events.entity_hooks')->nodeDelete($node);
}

